generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Campaign {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  niche     String
  location  String
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads Lead[]
}

model Lead {
  id           String        @id @default(cuid())
  campaignId   String
  businessName String
  phone        String?
  email        String?
  address      String?
  city         String?
  state        String?
  websiteUrl   String?
  source       String?
  status       String        @default("new")
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  campaign  Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  webAudit  LeadWebAudit?
  demoSite  DemoSite?
  callScript CallScript?
}

model LeadWebAudit {
  id                 String   @id @default(cuid())
  leadId             String   @unique
  hasWebsite         Boolean  @default(false)
  websiteQualityScore Int?
  issuesFoundJson    Json?
  summary            String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model DemoSite {
  id            String   @id @default(cuid())
  leadId         String   @unique
  slug           String   @unique
  nicheTemplate  String
  status         String   @default("draft")
  contentJson    Json
  publicUrl      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model CallScript {
  id               String   @id @default(cuid())
  leadId           String   @unique
  scriptText       String
  talkingPointsJson Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}
